# ========================================
# GST Bill Digitization — Environment Config
# ========================================

# Google Gemini API Key (free tier: https://aistudio.google.com/apikey)
# Required for AI classification. Without it, classifier returns "unclassified".
GOOGLE_API_KEY=your_gemini_api_key_here

# Database URL (SQLite default — change to postgresql:// for production)
DATABASE_URL=sqlite:///./gst_bills.db

# AI confidence threshold — bills below this go to manual review
# 0.7 is a safe default: not too strict, catches uncertain cases
CONFIDENCE_THRESHOLD=0.7

# Business context — tells AI what kind of company this is
# A medicine bill means different things to a pharma company vs a garment shop
BUSINESS_TYPE=trading
BUSINESS_DESCRIPTION=A general trading company dealing in electronics and office supplies
